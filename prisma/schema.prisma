generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String        @id @default(uuid())
  username                String       @unique
  password                String?
  email                   String?        @unique
  emailVerified           DateTime? // 添加 emailVerified 欄位
  phone                   String?
  phoneVerified           DateTime?
  name                    String?
  role                    UserRole
  teacherholidaysDateTime String[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  accounts                Accounts[]
  sessions                Session[]
  Order                   Order[]
  Cart                    Cart[]
  CourseModul             CourseModul[]
  Account                 Account[]
  Course                  Course[]
  OAuth                   OAuth[]
  Invoice                Invoice[]
  Receipt                Receipt[]
  specialCourse           specialCourse[]
}

model OAuth{
  id        String   @id @default(uuid())
  OAuthEmail              String        @unique 
  userId                  String
  User                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model School {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Certigificate {
  id          String        @id @default(uuid())
  name        String
  date        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  GroupUser   GroupUser[]
  GroupMember GroupMember[]
}

model GroupUser {
  id          String          @id @default(uuid())
  GroupName   String
  Groupmember String[]
  Certificate Certigificate[]
  Course      Course[]
  Date        String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  specialCourse         specialCourse[]
}

model GroupMember {
  id          String          @id @default(uuid())
  username    String
  Date        String[]
  Certificate Certigificate[]
  Course      Course[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  specialCourse         specialCourse[]
}

model Course {
  id                  String                @id @default(uuid())
  title               String
  description         String
  courseCode          String
  schoolName          String
  CourseTypes         String?
  startDate           String?
  endDate             String?
  Coursedates         String[]              @default([])
  numberOfDays        Float // 從 Int 改為 Float
  numberOfStudents     Int?
  maxStudents         Int?                  // 新增：人數上限字段，可選
  timeHours           Float // 從 Int 改為 Float
  timeRange           String[]              @default([]) // 儲存可用的時間段（例如 ["morning", "afternoon"]）應該用不到
  teacher             String[]              @default([])
  teacherId           String
  isPublic            Boolean
  isProductItem       Boolean //暫時不用
  isProduct           Boolean
  Producted           Boolean
  Students            String[]
  type                String[]              @default([])
  classroom           String? // 可選的課室欄位
  weekday             String? // 可選的週份欄位
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  GroupUser           GroupUser[]
  GroupMember         GroupMember[]
  CourseModul         CourseModul?          @relation(fields: [courseModulId], references: [id])
  courseModulId       String?
  CoursePorductType   CourseProductType[]
  CoursePorductStatue CourseProductStatus[]
  CourseTimeRanges    CourseTimeRange[] // 新增關聯到 CourseTimeRange
  Products            Product[] // 新增反向關聯
  Teacher             User?                 @relation(fields: [teacherId], references: [id])
}

