model CourseTimeRange {
  id        String   @id @default(uuid())
  courseId  String
  timeRange String
  starttime String?
  endtime   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  // 移除 specialCourse 關聯
}

// === Product 模型 ===
model Product {
  id                       String                @id @default(uuid())
  title                    String
  description              String
  Target_Audience          String?
  Course_Objective         String?
  Applicable_Scenarios     String?
  price                    Int
  real_price               Int
  CourseProductTypeArray   String[]              @default([])
  CourseProductStatusArray String[]              @default([])
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  IsPublic                 Boolean
  courseId                 String?               @map("course_id")
  specialCourseId          String?               @unique
  Course                   Course?               @relation(fields: [courseId], references: [id])
  isTrash                  Boolean?              @default(false)
  
  // 關鍵修正：使用正確模型名稱 specialCourse
  specialCourse            specialCourse?        @relation(fields: [specialCourseId], references: [id])
  
  CartItem                 CartItem[]
  OrderItem                OrderItem[]
  CourseProductType        CourseProductType[]
  CourseProductStatus      CourseProductStatus[]
  Product_Course_Dates     Product_Course_Dates[]
  Product_Course_Time_Ranges Product_Course_Time_Ranges[]
  Product_Img              Product_Img[]
  Product_video            Product_video[]
}

model Product_Course_Dates {
  id         String   @id @default(uuid())
  date       DateTime
  ProductId  String
  product    Product  @relation(fields: [ProductId], references: [id])
}

model Product_Course_Time_Ranges {
  id         String   @id @default(uuid())
  timeRange  String
  starttime  String?
  endtime    String?
  ProductId  String
  product    Product  @relation(fields: [ProductId], references: [id])
}


model Product_video{
  id        String   @id @default(uuid())
  video_url    String
  ProductId  String
  Product    Product @relation(fields: [ProductId], references: [id])
}

model Product_Img{
  id        String   @id @default(uuid())
  img_url    String
  ProductId  String
  Product    Product @relation(fields: [ProductId], references: [id])
}

model CourseModul {
  id                 String   @id @default(uuid())
  title              String
  description        String
  Teaching_Materials String?
  originalFileName   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  TeacherId          String
  Teacher            User     @relation(fields: [TeacherId], references: [id])
  Courses            Course[] // 反向關係，指向引用此 CourseModul 的所有 Course
  specialCourse      specialCourse[]
}

model Message_Box {
  id        String   @id @default(uuid())
  title     String
  content   String
  sender    String
  receiver  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Accounts {
  id          String   @id @default(uuid())
  client_name String // 改為 client_name
  title       String
  description String
  price       Int
  total       Int
  date        String
  client_id   String
  products    Json?
  Client_User User     @relation(fields: [client_id], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NITTP {
  id            String   @id @default(uuid())
  title         String
  description   String
  school_name   String
  day           String
  time          String
  time_h        Int
  teacher       String[]
  Ispublic      Boolean
  company_name  String
  company_price Int
  date_start    String
  date_end      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Homemade {
  id            String   @id @default(uuid())
  title         String
  description   String
  teacher       String[]
  Ispublic      Boolean
  Homemade_code String
  school_name   String
  day           String
  time          String
  time_h        Int
  date_start    String
  date_end      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ERB {
  id          String   @id @default(uuid())
  ERB_code    String
  title       String
  description String
  school_name String
  day         String
  time        String
  time_h      Int
  teacher     String[]
  Ispublic    Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  total     Float
  status    String      @default("PENDING")
  paymentId String?     // 新增：儲存 PayMe 或其他支付閘道的支付 ID
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]
  user      User        @relation(fields: [userId], references: [id])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model CourseProductType {
  id        String    @id @default(uuid())
  typename  String
  author    String
  role      UserRole
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Product   Product[]
  Course    Course[]
  specialCourse   specialCourse[]
}

model CourseProductStatus {
  id         String    @id @default(uuid())
  statuename String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  Product    Product[]
  Course     Course[]
  specialCourse   specialCourse[]
}

model HeaderType {
  id             String   @id @default(uuid())
  HeaderTypeName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// prisma/schema.prisma
model Invoice {
  id               String   @id @default(cuid())
  title            String
  description      String?
  content          String[]
  studentname      String
  student_id       String
  Invoice_id       String   @unique
  price            Float
  total            Float    // 新增：總金額（price * quantity）
  date             DateTime // 新增：這才是你要的欄位！
  servetype        String
  PaymentMethods   String[]
  DB               Float
  adminFee         Float
  isPayment        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  User             User[]
  PaymentMethods_price PaymentMethods_price[]
}


model Receipt {
  id          String  @id @default(cuid())
  title       String
  content     String[]
  // parentId    String?
  studentname  String
  invoicebydbid   String
  Invoice_id   String
  servetype       String
  isPayment        Boolean 
  DB Float
  adminFee          Float
  price           Float
  PaymentMethods  String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  User            User[]
}

model PaymentMethods_price {
  id          String  @id @default(cuid())
  Invoice_id  String
  Invoice     Invoice[]
  price       Float
  Item_name   String[]
  PaymentMethods String
  craetedAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

// schema.prisma
model specialCourse {
  id               String    @id @default(uuid())
  title            String
  description      String
  courseCode       String
  schoolName       String
  numberOfDays     Int
  numberOfStudents Int?
  maxStudents      Int?
  timeHours        Int
  teacher          String[]
  teacherId        String
  isPublic         Boolean
  isProduct        Boolean   @default(false)
  Producted        Boolean   @default(false)
  type             String[]
  courseModulId    String?
  startDate        DateTime?
  endDate          DateTime?
  Coursedates      DateTime[]
  weekday          String?
  classroom        String?

  // === 新增：Product 欄位（直接內嵌）===
  price            Int?
  real_price       Int?
  Target_Audience  String?
  Course_Objective String?
  Applicable_Scenarios String?

  // === 圖片 & 影片（用 JSON 存）===
  IMG_URL          Json?     // [{ id: "1", img_url: "https://..." }]
  Video_URL        Json?     // [{ id: "1", video_url: "https://..." }] 或 YouTube ID

  // === 關聯（保留，可選）===
  // product          Product?  @relation(fields: [productId], references: [id])
  // productId        String?
  products                 Product[]  // ← 反向關係
  SpecialCourseTimeRanges SpecialCourseTimeRange[]
  Students         User[]
  GroupUser           GroupUser[]
  GroupMember         GroupMember[]
  CoursePorductType   CourseProductType[]  // 新增這行
  CoursePorductStatue CourseProductStatus[]  // 新增這行
  CourseModul         CourseModul?          @relation(fields: [courseModulId], references: [id])
}


