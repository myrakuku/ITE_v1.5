model SpecialCourseTimeRange {
  id        String   @id @default(uuid())
  courseId  String
  timeRange String
  starttime String?
  endtime   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    specialCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  ADMIN
  TEACHER
}
